---
import { projects } from '../data/projects';

const copies = 9;
const middleCopy = Math.floor(copies / 2);
const repeatedProjects = Array.from({ length: copies }, () => projects).flat();
---

<section
  class="project-home"
  data-infinite-project-list
  data-project-count={projects.length}
  data-copies={copies}
  aria-label="Featured projects"
>
  <div class="project-preview" data-project-preview>
    {
      projects.map((project, index) => (
        <a
          class:list={['project-preview__link', index === 0 && 'is-active']}
          href={project.href}
          aria-label={`View ${project.clientName}`}
          data-project-preview-link
          data-project-index={index}
        >
          <img
            class="project-preview__image"
            src={project.mainImageUrl}
            alt={project.mainImage.alt || ''}
            loading={index === 0 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </a>
      ))
    }
  </div>

  <div class="project-list-section">
    <div class="project-list__viewport" data-project-viewport>
      <div class="project-list__track" data-project-track>
        {
          repeatedProjects.map((project, index) => {
            const isInitialActive = index === middleCopy * projects.length;
            return (
              <a
                class:list={['project-item', isInitialActive && 'is-active']}
                href={project.href}
                data-project-index={index % projects.length}
                aria-current={isInitialActive ? 'true' : undefined}
                aria-hidden={String(!isInitialActive)}
                tabindex={isInitialActive ? '0' : '-1'}
              >
                <span class="project-number">{project.number}</span>
                <span class="project-title">{project.clientName}</span>
                <span class="project-arrow" aria-hidden="true">&gt;</span>
              </a>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<style>
  .project-home {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    padding: 88px 1.5rem 112px;
    color: var(--foreground);
    background: #f5f5f2;
    touch-action: none;
    user-select: none;
    cursor: grab;
  }

  .project-home.is-dragging {
    cursor: grabbing;
  }

  .project-preview {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(42vw, 560px);
    height: min(55vh, 620px);
    background: rgba(0, 0, 0, 0.025);
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .project-preview__link {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    opacity: 0;
    pointer-events: none;
    transform: scale(0.985);
    transition:
      opacity 0.28s ease,
      transform 0.42s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project-preview__link.is-active {
    opacity: 1;
    pointer-events: auto;
    transform: scale(1);
  }

  .project-preview__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-list-section {
    position: absolute;
    left: 0;
    right: 0;
    bottom: clamp(14px, 2vw, 28px);
    padding: 0 1.5rem;
  }

  .project-list__viewport {
    width: min(100%, 1160px);
    height: var(--item-height, 70px);
    margin: 0 auto;
    overflow: hidden;
  }

  .project-list__track {
    will-change: transform;
  }

  .project-item {
    width: 100%;
    height: var(--item-height, 70px);
    display: grid;
    grid-template-columns: 68px minmax(0, 1fr) auto;
    align-items: center;
    gap: 12px;
    padding: 0 1.5rem;
    color: inherit;
    text-decoration: none;
  }

  .project-number,
  .project-arrow {
    font-family: var(--font-mono);
    font-weight: 650;
    font-variant-numeric: tabular-nums;
  }

  .project-number {
    font-size: clamp(17px, 1.35vw, 22px);
    line-height: 1;
  }

  .project-title {
    min-width: 0;
    overflow: hidden;
    font-family: inherit;
    font-size: clamp(38px, 5vw, 72px);
    font-weight: 400;
    line-height: 0.84;
    letter-spacing: -0.065em;
    text-overflow: clip;
    white-space: nowrap;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project-arrow {
    font-size: clamp(28px, 3.5vw, 48px);
    line-height: 1;
    opacity: 0;
    transform: translateX(-10px);
    transition:
      opacity 0.25s ease,
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project-item.is-active:hover .project-arrow,
  .project-item.is-active:focus-visible .project-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .project-item.is-active:hover .project-title,
  .project-item.is-active:focus-visible .project-title {
    transform: translateX(6px);
  }

  .project-item:focus {
    outline: none;
  }

  .project-item:focus-visible {
    outline: 1px solid currentColor;
    outline-offset: 4px;
  }

  @media (max-width: 700px) {
    .project-home {
      padding: 78px 1.5rem 96px;
    }

    .project-preview {
      width: min(78vw, 380px);
      height: min(48vh, 440px);
    }

    .project-list-section {
      bottom: 16px;
      padding: 0 1.5rem;
    }

    .project-item {
      grid-template-columns: 50px minmax(0, 1fr) auto;
      gap: 8px;
      padding: 0 1.5rem;
    }

    .project-number {
      font-size: 20px;
    }

    .project-title {
      font-size: clamp(32px, 10vw, 56px);
    }
  }

  @media (hover: none) {
    .project-arrow {
      display: none;
    }

    .project-item {
      grid-template-columns: 50px minmax(0, 1fr);
    }
  }
</style>

<script>
  const projectListSelector = '[data-infinite-project-list]';

  const initInfiniteProjectList = (root) => {
    if (!(root instanceof HTMLElement)) {
      return;
    }

    if (typeof root.__infiniteProjectListCleanup === 'function') {
      root.__infiniteProjectListCleanup();
    }

    const track = root.querySelector('[data-project-track]');
    const preview = root.querySelector('[data-project-preview]');
    const previewLinks = Array.from(root.querySelectorAll('[data-project-preview-link]'));
    const items = Array.from(root.querySelectorAll('.project-item'));
    const projectCount = Number(root.dataset.projectCount || previewLinks.length);
    const copies = Number(root.dataset.copies || 9);

    if (
      !(track instanceof HTMLElement) ||
      !(preview instanceof HTMLElement) ||
      previewLinks.length === 0 ||
      projectCount === 0 ||
      items.length === 0
    ) {
      return;
    }

    const middleCopy = Math.floor(copies / 2);
    let itemHeight = 70;
    let currentIndex = middleCopy * projectCount;
    let currentY = 0;
    let targetY = 0;
    let wheelDelta = 0;
    let lastWheelStep = 0;
    let animationFrame = 0;
    let activeProjectIndex = -1;
    let isDragging = false;
    let pointerStartY = 0;
    let pointerStartX = 0;
    let dragStartTargetY = 0;
    let activePointerId = null;
    let suppressNextClick = false;
    let transitionDirection = 1;

    const wheelThreshold = 24;
    const wheelCooldown = 80;

    const getProjectIndex = (index) => ((index % projectCount) + projectCount) % projectCount;

    const getRenderedIndex = (index) => ((index % items.length) + items.length) % items.length;

    const updateActiveImage = (projectIndex) => {
      previewLinks.forEach((link) => {
        if (!(link instanceof HTMLElement)) {
          return;
        }

        link.classList.toggle('is-active', Number(link.dataset.projectIndex) === projectIndex);
      });
    };

    const setActiveProject = (index, direction = 1) => {
      const projectIndex = getProjectIndex(index);
      const renderedIndex = getRenderedIndex(Math.round(index));

      items.forEach((item, itemIndex) => {
        const isActive = itemIndex === renderedIndex;

        item.classList.toggle('is-active', isActive);
        item.setAttribute('aria-hidden', String(!isActive));
        item.setAttribute('tabindex', isActive ? '0' : '-1');

        if (isActive) {
          item.setAttribute('aria-current', 'true');
        } else {
          item.removeAttribute('aria-current');
        }
      });

      if (projectIndex === activeProjectIndex) {
        return;
      }

      activeProjectIndex = projectIndex;
      transitionDirection = direction || 1;
      updateActiveImage(projectIndex);
    };

    const setTrackPosition = () => {
      track.style.transform = `translate3d(0, ${currentY}px, 0)`;
    };

    const syncTargetToIndex = () => {
      targetY = -currentIndex * itemHeight;
    };

    const nearestIndexFromY = (y) => Math.round(-y / itemHeight);

    const recenterIfNeeded = () => {
      const lowEdge = projectCount * 2;
      const highEdge = projectCount * (copies - 2);
      const referenceIndex = nearestIndexFromY(targetY);
      let shift = 0;

      if (referenceIndex < lowEdge) {
        shift = projectCount * middleCopy;
      } else if (referenceIndex >= highEdge) {
        shift = -projectCount * middleCopy;
      }

      if (shift === 0) {
        return;
      }

      const yShift = -shift * itemHeight;
      currentIndex += shift;
      currentY += yShift;
      targetY += yShift;
      dragStartTargetY += yShift;
      setTrackPosition();
    };

    const snapToIndex = (index, direction = index > currentIndex ? 1 : -1) => {
      currentIndex = index;
      syncTargetToIndex();
      recenterIfNeeded();
      setActiveProject(currentIndex, direction);
    };

    const step = (direction) => {
      snapToIndex(currentIndex + direction, direction);
    };

    const animate = () => {
      recenterIfNeeded();
      currentY += (targetY - currentY) * 0.16;

      if (Math.abs(targetY - currentY) < 0.02) {
        currentY = targetY;
      }

      setTrackPosition();

      animationFrame = window.requestAnimationFrame(animate);
    };

    const measure = () => {
      const activeProject = getProjectIndex(currentIndex);
      itemHeight = Math.max(48, Math.min(window.innerWidth * 0.05, 70));
      root.style.setProperty('--item-height', `${itemHeight}px`);

      currentIndex = middleCopy * projectCount + activeProject;
      syncTargetToIndex();
      currentY = targetY;
      setTrackPosition();
      setActiveProject(currentIndex, transitionDirection);
    };

    const onWheel = (event) => {
      event.preventDefault();
      wheelDelta += event.deltaY;
      const now = performance.now();

      if (Math.abs(wheelDelta) < wheelThreshold || now - lastWheelStep < wheelCooldown) {
        return;
      }

      const direction = wheelDelta > 0 ? 1 : -1;
      wheelDelta = 0;
      lastWheelStep = now;
      step(direction);
    };

    const onPointerDown = (event) => {
      if (event.button !== undefined && event.button !== 0) {
        return;
      }

      if (event.target instanceof Element && event.target.closest('a')) {
        suppressNextClick = false;
        return;
      }

      isDragging = true;
      activePointerId = event.pointerId;
      pointerStartY = event.clientY;
      pointerStartX = event.clientX;
      dragStartTargetY = targetY;
      suppressNextClick = false;
      root.classList.add('is-dragging');
      root.setPointerCapture(event.pointerId);
    };

    const onPointerMove = (event) => {
      if (!isDragging || event.pointerId !== activePointerId) {
        return;
      }

      const deltaY = event.clientY - pointerStartY;
      const deltaX = event.clientX - pointerStartX;

      if (Math.hypot(deltaX, deltaY) > 6) {
        suppressNextClick = true;
      }

      targetY = dragStartTargetY + deltaY;
      setActiveProject(nearestIndexFromY(targetY), deltaY < 0 ? 1 : -1);
    };

    const endDrag = (event) => {
      if (!isDragging || event.pointerId !== activePointerId) {
        return;
      }

      isDragging = false;
      activePointerId = null;
      root.classList.remove('is-dragging');

      if (root.hasPointerCapture(event.pointerId)) {
        root.releasePointerCapture(event.pointerId);
      }

      snapToIndex(nearestIndexFromY(targetY), targetY < dragStartTargetY ? 1 : -1);
    };

    const onClick = (event) => {
      const link = event.target instanceof Element ? event.target.closest('a') : null;

      if (!(link instanceof HTMLAnchorElement)) {
        return;
      }

      if (isDragging || suppressNextClick) {
        event.preventDefault();
      }

      suppressNextClick = false;
    };

    const onKeyDown = (event) => {
      if (event.key === 'ArrowDown') {
        event.preventDefault();
        step(1);
      }

      if (event.key === 'ArrowUp') {
        event.preventDefault();
        step(-1);
      }
    };

    const cleanup = () => {
      window.cancelAnimationFrame(animationFrame);
      root.removeEventListener('wheel', onWheel);
      root.removeEventListener('pointerdown', onPointerDown);
      root.removeEventListener('pointermove', onPointerMove);
      root.removeEventListener('pointerup', endDrag);
      root.removeEventListener('pointercancel', endDrag);
      root.removeEventListener('click', onClick);
      window.removeEventListener('keydown', onKeyDown);
      window.removeEventListener('resize', measure);
      document.removeEventListener('astro:before-swap', cleanup);
      root.classList.remove('is-dragging');
      delete root.__infiniteProjectListCleanup;
    };

    root.addEventListener('wheel', onWheel, { passive: false });
    root.addEventListener('pointerdown', onPointerDown);
    root.addEventListener('pointermove', onPointerMove);
    root.addEventListener('pointerup', endDrag);
    root.addEventListener('pointercancel', endDrag);
    root.addEventListener('click', onClick);
    window.addEventListener('keydown', onKeyDown);
    window.addEventListener('resize', measure);
    document.addEventListener('astro:before-swap', cleanup, { once: true });

    root.__infiniteProjectListCleanup = cleanup;

    measure();
    animationFrame = window.requestAnimationFrame(animate);
  };

  const initInfiniteProjectLists = () => {
    document.querySelectorAll(projectListSelector).forEach(initInfiniteProjectList);
  };

  initInfiniteProjectLists();
  document.addEventListener('astro:page-load', initInfiniteProjectLists);
</script>
