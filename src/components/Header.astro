---
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const navItems = [
  { href: '/', label: 'Home', active: pathname === '/' },
  { href: '/about', label: 'About', active: pathname === '/about' },
  { href: '/works', label: 'Works', active: pathname.startsWith('/works') || pathname.startsWith('/work') },
  { href: '/contact', label: 'Contact', active: pathname === '/contact' },
];
---

<header class="site-header">
  <nav class="site-nav" aria-label="Primary navigation">
    <a class="nav-logo" href="/">Sandikala Studio</a>
    <div class="nav-links">
      {
        navItems.map((item) => (
          <a class:list={['nav-link', item.active && 'is-active']} href={item.href} aria-current={item.active ? 'page' : undefined}>
            {item.label}
          </a>
        ))
      }
      <a class="nav-link" href="mailto:hello@sandikalastudio.com">Schedule a call</a>
    </div>
  </nav>
</header>
