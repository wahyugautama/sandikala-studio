---
import '../styles/barba-demo.css';

interface Props {
  title?: string;
  namespace: 'demo-a' | 'demo-b';
}

const { title = 'Barba Shared Element Demo', namespace } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Shared-element page transition demo using Barba.js, GSAP, and GSAP Flip." />
    <title>{title}</title>
  </head>
  <body data-barba="wrapper">
    <div class="shared-transition-layer" aria-hidden="true"></div>
    <main class="barba-demo-main" data-barba="container" data-barba-namespace={namespace}>
      <slot />
    </main>
    <script type="module" is:inline>
      import '/src/scripts/barba-demo.ts';
    </script>
  </body>
</html>
