---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact — Sandikala Studio"
  description="Contact Sandikala Studio for selected design and development collaborations."
>
  <article class="contact-page">
    <header class="contact-hero">
      <p class="contact-eyebrow">Contact</p>
      <h1>Let’s shape a digital experience with intent.</h1>
    </header>

    <section class="contact-content" aria-label="Contact details">
      <div class="contact-copy">
        <p>
          We partner with founders, teams, and cultural organisations on focused digital
          products, websites, and brand systems.
        </p>
        <p>
          Send a short note about the project, timing, and what needs to move. We usually reply
          within two business days.
        </p>
      </div>

      <div class="contact-details">
        <a class="contact-link" href="mailto:hello@sandikalastudio.com">hello@sandikalastudio.com</a>
        <a class="contact-link" href="mailto:hello@sandikalastudio.com">Schedule a call</a>
      </div>
    </section>
  </article>
</Layout>

<style>
  .contact-page {
    min-height: 100svh;
    padding: 116px 32px 80px;
    background: #f5f5f2;
  }

  .contact-hero,
  .contact-content {
    max-width: 1180px;
    margin: 0 auto;
  }

  .contact-eyebrow {
    margin: 0 0 18px;
    font-size: 14px;
    line-height: 1;
  }

  .contact-hero h1 {
    max-width: 1000px;
    margin: 0 0 clamp(70px, 10vw, 130px);
    font-size: clamp(54px, 9vw, 140px);
    font-weight: 400;
    line-height: 0.86;
    letter-spacing: -0.065em;
  }

  .contact-content {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.42fr);
    gap: clamp(48px, 8vw, 130px);
  }

  .contact-copy {
    display: grid;
    gap: 24px;
    max-width: 720px;
  }

  .contact-copy p,
  .contact-link {
    margin: 0;
    font-size: 17px;
    line-height: 1.45;
  }

  .contact-details {
    display: grid;
    align-content: start;
    gap: 10px;
  }

  .contact-link {
    width: fit-content;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  @media (max-width: 700px) {
    .contact-page {
      padding: 94px 20px 56px;
    }

    .contact-hero h1 {
      font-size: clamp(44px, 14vw, 76px);
    }

    .contact-content {
      grid-template-columns: 1fr;
    }
  }
</style>
