---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
---

<Layout title="Works — Sandikala Studio" description="Selected Sandikala Studio projects.">
  <section class="works-page">
    <header class="works-header">
      <h1>Works</h1>
    </header>
    <div class="works-list">
      {
        projects.map((project) => (
          <a class="works-item" href={project.href}>
            <span class="works-item__number">{project.number}</span>
            <span class="works-item__title">{project.title}</span>
            <span class="works-item__meta">{project.year} / {project.category}</span>
          </a>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  .works-page {
    min-height: 100svh;
    padding: 116px 1.5rem 80px;
    background: #f5f5f2;
  }

  .works-header,
  .works-list {
    max-width: 1180px;
    margin: 0 auto;
  }

  .works-header h1 {
    margin: 0 0 clamp(56px, 8vw, 104px);
    font-size: var(--type-h1);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: 0;
  }

  .works-list {
    display: grid;
  }

  .works-item {
    display: grid;
    grid-template-columns: 68px minmax(0, 1fr) auto;
    align-items: center;
    gap: 12px;
    padding: 18px 0;
    border-top: 1px solid color-mix(in srgb, var(--foreground) 14%, transparent);
  }

  .works-item:last-child {
    border-bottom: 1px solid color-mix(in srgb, var(--foreground) 14%, transparent);
  }

  .works-item__number {
    font-family: var(--font-mono);
    font-weight: 650;
    font-variant-numeric: tabular-nums;
  }

  .works-item__title {
    min-width: 0;
    overflow: hidden;
    font-size: clamp(34px, 5vw, 72px);
    font-weight: 400;
    line-height: 0.84;
    letter-spacing: -0.065em;
    white-space: nowrap;
  }

  .works-item__meta {
    font-size: 14px;
    white-space: nowrap;
  }

  @media (max-width: 700px) {
    .works-page {
      padding: 94px 1.5rem 56px;
    }

    .works-item {
      grid-template-columns: 50px minmax(0, 1fr);
    }

    .works-item__meta {
      grid-column: 2;
      white-space: normal;
    }

    .works-item__title {
      font-size: clamp(32px, 10vw, 56px);
    }
  }
</style>
