---
import Layout from '../../layouts/Layout.astro';
import { projects, type Project } from '../../data/projects';
import { urlFor } from '../../lib/sanity';

interface Props {
  project: Project;
}

export function getStaticPaths() {
  return projects.map((project) => ({
    params: {
      slug: project.slug,
    },
    props: {
      project,
    },
  }));
}

const { project } = Astro.props;
const projectIndex = projects.findIndex((item) => item.slug === project.slug);
const nextProject = projects[(projectIndex + 1) % projects.length];
const galleryImages = project.imageGallery ?? [];

function getGalleryImageUrl(image: NonNullable<Project['imageGallery']>[number]) {
  if (image.url) {
    return image.url;
  }

  if (!image.asset?._ref) {
    return '';
  }

  return urlFor(image).width(1800).quality(85).auto('format').url();
}

const gallery = galleryImages
  .map((image) => ({
    src: getGalleryImageUrl(image),
    alt: image.alt || '',
  }))
  .filter((image) => image.src);
---

<Layout title={`${project.clientName} — Sandikala Studio`} description={project.projectOverview}>
  <article class="project-page">
    <header class="project-hero">
      <h1 class="project-hero__title">{project.clientName}</h1>
    </header>

    <figure class="project-main-image">
      <img
        class="project-hero__image"
        src={project.mainImageUrl}
        alt={project.mainImage.alt || ''}
        loading="eager"
        decoding="async"
      />
    </figure>

    <dl class="project-meta">
      <div>
        <dt>Year</dt>
        <dd>{project.year}</dd>
      </div>
      <div>
        <dt>Industry</dt>
        <dd>{project.industry}</dd>
      </div>
      <div>
        <dt>Services</dt>
        <dd>{project.services.join(', ')}</dd>
      </div>
    </dl>

    <section class="project-overview" aria-label="Project overview">
      <p>{project.projectOverview}</p>
    </section>

    {
      gallery.length > 0 && (
        <section class="project-gallery" aria-label={`${project.clientName} gallery`}>
          {gallery.map((image) => (
            <img
              src={image.src}
              alt={image.alt}
              loading="lazy"
              decoding="async"
            />
          ))}
        </section>
      )
    }

    {
      nextProject && (
        <a class="next-project" href={nextProject.href}>
          <span class="next-project__label">Next project</span>
          <span class="next-project__row">
            <span class="next-project__number">{nextProject.number}</span>
            <span class="next-project__title">{nextProject.clientName}</span>
            <span class="next-project__arrow" aria-hidden="true">&gt;</span>
          </span>
        </a>
      )
    }
  </article>
</Layout>

<style>
  .project-page {
    padding: 116px 1.5rem 80px;
    background: #f5f5f2;
  }

  .project-hero {
    max-width: 100%;
    margin: 0 auto;
  }

  .project-hero__title {
    margin: 0 0 42px;
    font-size: var(--type-h1);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: 0;
  }

  .project-main-image {
    max-width: 100%;
    margin: 0 auto;
  }

  .project-hero__image {
    display: block;
    width: 100%;
    height: auto;
  }

  .project-meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    max-width: 1180px;
    margin: clamp(52px, 8vw, 96px) auto;
  }

  .project-meta div {
    display: grid;
    gap: 8px;
  }

  .project-meta dt {
    margin: 0;
    font-size: 14px;
    color: var(--muted);
  }

  .project-meta dd {
    margin: 0;
    font-size: 17px;
    line-height: 1.35;
  }

  .project-overview {
    max-width: 1180px;
    margin: 0 auto clamp(70px, 10vw, 140px);
  }

  .project-overview p {
    margin: 0;
    max-width: 58ch;
    font-size: 17px;
    line-height: 1.45;
    white-space: pre-line;
  }

  .project-gallery {
    display: grid;
    gap: clamp(48px, 8vw, 112px);
    max-width: 1180px;
    margin: 0 auto;
  }

  .project-gallery img {
    display: block;
    width: 100%;
    height: auto;
  }

  .next-project {
    display: block;
    max-width: 1180px;
    margin: clamp(78px, 12vw, 150px) auto 0;
    padding: 28px 0 0;
    border-top: 1px solid color-mix(in srgb, var(--foreground) 18%, transparent);
  }

  .next-project__label {
    display: block;
    margin-bottom: 18px;
    font-size: 14px;
  }

  .next-project__row {
    display: grid;
    grid-template-columns: 68px minmax(0, 1fr) auto;
    align-items: center;
    gap: 12px;
  }

  .next-project__number,
  .next-project__arrow {
    font-family: var(--font-mono);
    font-weight: 650;
    font-variant-numeric: tabular-nums;
  }

  .next-project__title {
    min-width: 0;
    overflow: hidden;
    font-size: clamp(38px, 5vw, 72px);
    font-weight: 400;
    line-height: 0.84;
    letter-spacing: -0.065em;
    white-space: nowrap;
    text-overflow: clip;
  }

  .next-project__arrow {
    font-size: clamp(28px, 3.5vw, 48px);
    line-height: 1;
  }

  @media (max-width: 700px) {
    .project-page {
      padding: 94px 1.5rem 56px;
    }

    .project-hero__title {
      margin-bottom: 30px;
    }

    .project-meta {
      grid-template-columns: 1fr;
      margin: 42px auto 56px;
    }

    .next-project__row {
      grid-template-columns: 50px minmax(0, 1fr) auto;
      gap: 8px;
    }

    .next-project__title {
      font-size: clamp(32px, 10vw, 56px);
    }
  }
</style>
