---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About — Sandikala Studio"
  description="Sandikala Studio is an independent design and development studio creating distinctive digital experiences."
>
  <article class="about-page">
    <header class="about-hero">
      <h1>Independent design and development studio creating thoughtful digital experiences.</h1>
    </header>

    <section class="about-content" aria-label="Studio description">
      <div class="about-copy">
        <p>
          Sandikala Studio is an independent design and development studio creating distinctive
          digital experiences for brands, organisations, and cultural projects.
        </p>
        <p>
          We work across strategy, art direction, UX/UI, interaction design, and creative
          development. Our approach combines clear systems with expressive visual ideas, creating
          websites that feel considered, memorable, and useful.
        </p>
      </div>

      <div class="about-details">
        <section class="about-block" aria-labelledby="capabilities-title">
          <h2 id="capabilities-title">Capabilities</h2>
          <ul>
            <li>Strategy</li>
            <li>Creative Direction</li>
            <li>Brand Experience</li>
            <li>UX/UI Design</li>
            <li>Interaction Design</li>
            <li>Webflow Development</li>
            <li>Creative Development</li>
          </ul>
        </section>

        <section class="about-block" aria-labelledby="information-title">
          <h2 id="information-title">Information</h2>
          <p>Based in Bali, working internationally.</p>
          <p>Available for selected collaborations.</p>
          <a href="mailto:hello@sandikalastudio.com">hello@sandikalastudio.com</a>
        </section>
      </div>
    </section>
  </article>
</Layout>

<style>
  .about-page {
    min-height: 100svh;
    padding: 116px 32px 80px;
    background: #f5f5f2;
  }

  .about-hero,
  .about-content {
    max-width: 1180px;
    margin: 0 auto;
  }

  .about-hero h1 {
    max-width: 980px;
    margin: 0 0 clamp(70px, 10vw, 130px);
    font-size: clamp(50px, 8vw, 118px);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.06em;
  }

  .about-content {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.45fr);
    gap: clamp(48px, 8vw, 130px);
  }

  .about-copy {
    display: grid;
    gap: 24px;
    max-width: 720px;
  }

  .about-copy p,
  .about-block p,
  .about-block a,
  .about-block li {
    margin: 0;
    font-size: 17px;
    line-height: 1.45;
  }

  .about-details {
    display: grid;
    gap: 48px;
  }

  .about-block h2 {
    margin: 0 0 18px;
    font-size: 14px;
    font-weight: 400;
  }

  .about-block ul {
    display: grid;
    gap: 7px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .about-block {
    display: grid;
    gap: 8px;
  }

  .about-block a {
    width: fit-content;
    margin-top: 10px;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  @media (max-width: 700px) {
    .about-page {
      padding: 94px 20px 56px;
    }

    .about-hero h1 {
      font-size: clamp(42px, 14vw, 72px);
    }

    .about-content {
      grid-template-columns: 1fr;
    }
  }
</style>
