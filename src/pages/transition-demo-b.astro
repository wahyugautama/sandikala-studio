---
import BarbaDemoLayout from '../layouts/BarbaDemoLayout.astro';

const demoImage =
  'https://images.unsplash.com/photo-1487958449943-2429e8be8625?auto=format&fit=crop&w=1800&q=85';
---

<BarbaDemoLayout title="Transition Demo B" namespace="demo-b">
  <article class="demo-page demo-page-b" aria-labelledby="demo-b-title">
    <header class="demo-b-hero">
      <div class="demo-b-title-wrap">
        <p class="demo-kicker" data-page-reveal>Case study</p>
        <h1 id="demo-b-title" class="demo-b-title" data-flip-id="demo-title">Project Atlas</h1>
      </div>

      <figure class="demo-b-image" data-flip-id="demo-image">
        <img src={demoImage} alt="Modern architectural courtyard for Project Atlas" width="1800" height="1200" />
      </figure>

      <div class="demo-b-meta" data-page-reveal>
        <span>Brand Identity / 2026</span>
        <span>Spatial system for a future-facing cultural district.</span>
      </div>
    </header>

    <section class="demo-b-content" data-page-reveal>
      <p>
        Project Atlas frames architecture, signage, and digital touchpoints as one continuous identity system.
        The transition demo keeps the image and title visually continuous while the surrounding page changes.
      </p>
      <a class="demo-b-link" href="/transition-demo-a">Back to index</a>
    </section>
  </article>
</BarbaDemoLayout>
